<DModal @title={{i18n "user_status.set_custom_status"}} @closeModal={{@closeModal}} class="user-status-custom-modal user-status">
  <:body>
    <div class="user-status-modal-content">
      
      {{#if this.history.length}}
        <div class="status-section">
          <h3>Häufig genutzt</h3>
          <div class="history-grid">
            {{#each this.history as |hist|}}
              <DButton
                class="btn-default preset-btn"
                @translatedAriaLabel={{hist.name}}
                @action={{fn this.setQuickStatus hist.emoji hist.name}}
              >
                <span aria-hidden="true">{{replace-emoji (concat ":" hist.emoji ":")}}</span>
                <span class="preset-name">{{hist.name}}</span>
              </DButton>
            {{/each}}
          </div>
        </div>
      {{/if}}

      <div class="status-section">
        <h3>Schnellauswahl</h3>
        <div class="preset-grid">
          {{#each this.presets as |preset|}}
            <DButton
              class="btn-default preset-btn"
              @translatedAriaLabel={{preset.name}}
              @action={{fn this.setQuickStatus preset.emoji preset.name}}
            >
              <span aria-hidden="true">{{replace-emoji (concat ":" preset.emoji ":")}}</span>
              <span class="preset-name">{{preset.name}}</span>
            </DButton>
          {{/each}}
        </div>
      </div>

      <div class="status-section custom-status">
        <h3>Eigener Status</h3>
        <div class="control-group">
          <UserStatusPicker @status={{this.status}} />
        </div>

        {{#unless this.hidePauseNotifications}}
          <div class="control-group pause-notifications" style="margin-top: 15px;">
            <label class="checkbox-label">
              <Input @type="checkbox" @checked={{this.pauseNotifications}} />
              {{i18n "user_status.pause_notifications"}}
            </label>
          </div>
        {{/unless}}

        <div class="control-group control-group-remove-status" style="margin-top: 15px;">
          <h3>{{i18n "user_status.remove_status"}}</h3>

          <div class="custom-time-picker-wrapper">
            <DButton 
              class="btn-default btn {{if this.isCustomActive 'active'}}" 
              @action={{this.toggleCustomPicker}}
            >
              Datum und Uhrzeit auswählen
            </DButton>

            {{#if this.showCustomPicker}}
              <div class="native-date-picker-container">
                <input 
                  type="datetime-local" 
                  value={{this.customDateTimeLocal}}
                  {{on "change" this.onCustomDateTimeChange}}
                  class="native-date-input"
                />
              </div>
            {{/if}}
          </div>

          <div class="inline-time-shortcuts">
            {{#each this.inlineTimeShortcuts as |shortcut|}}
              <DButton 
                class="btn-default time-shortcut-btn {{shortcut.activeClass}}" 
                @action={{fn this.setInlineTime shortcut.id shortcut.time}}
              >
                {{shortcut.name}}
              </DButton>
            {{/each}}
          </div>
        </div>
      </div>
    </div>
  </:body>

  <:footer>
    <DButton
      @label="user_status.save"
      @disabled={{this.saveDisabled}}
      @action={{this.saveStatus}}
      class="btn-primary"
    />

    <DModalCancel @close={{@closeModal}} />

    {{#if this.showDeleteButton}}
      <DButton
        @icon="trash-can"
        @action={{this.deleteStatus}}
        class="delete-status btn-danger"
      />
    {{/if}}
  </:footer>
</DModal>